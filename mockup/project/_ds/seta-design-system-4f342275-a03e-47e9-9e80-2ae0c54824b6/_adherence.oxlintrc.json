{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/agent/**",
              "components/core/**",
              "components/planner/**",
              "ui_kits/agent-platform/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Geist|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: Geist, Geist Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|src|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, size, src."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatComposer'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|onSubmit|placeholder|pending|disabled|permissionHint|onAttach|className|style|key|ref|className|style|children)$/]",
        "message": "<ChatComposer> doesn't accept that prop. Declared props: value, onChange, onSubmit, placeholder, pending, disabled, permissionHint, onAttach, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatMessage'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|author|timestamp|dim|className|style|children|key|ref|className|style|children)$/]",
        "message": "<ChatMessage> doesn't accept that prop. Declared props: variant, author, timestamp, dim, className, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatMessage'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:user|agent)$/]",
        "message": "<ChatMessage> variant must be one of 'user' | 'agent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatToolCall'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|status|summary|duration|payload|className|style|key|ref|className|style|children)$/]",
        "message": "<ChatToolCall> doesn't accept that prop. Declared props: name, status, summary, duration, payload, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatToolCall'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:running|ok|error)$/]",
        "message": "<ChatToolCall> status must be one of 'running' | 'ok' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HitlCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:intent|riskBadge|summary|countdown|countdownTier|primaryLabel|declineLabel|pending|disabled|onApprove|onDecline|children|className|style|key|ref|className|style|children)$/]",
        "message": "<HitlCard> doesn't accept that prop. Declared props: intent, riskBadge, summary, countdown, countdownTier, primaryLabel, declineLabel, pending, disabled, onApprove, onDecline, children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='HitlCard'] > JSXAttribute[name.name='riskBadge'] > Literal[value!=/^(?:write|destructive|external)$/]",
        "message": "<HitlCard> riskBadge must be one of 'write' | 'destructive' | 'external'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HitlCard'] > JSXAttribute[name.name='countdownTier'] > Literal[value!=/^(?:ok|soon|urgent)$/]",
        "message": "<HitlCard> countdownTier must be one of 'ok' | 'soon' | 'urgent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: size."
      },
      {
        "selector": "JSXOpeningElement[name.name='KanbanTask'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|title|priority|start_label|due_label|label|assignees|blocked|isCompleted|checklist_summary|key|ref|className|style|children)$/]",
        "message": "<KanbanTask> doesn't accept that prop. Declared props: id, title, priority, start_label, due_label, label, assignees, blocked, isCompleted, checklist_summary."
      },
      {
        "selector": "JSXOpeningElement[name.name='KbdHint'] > JSXAttribute > JSXIdentifier[name!=/^(?:keys|key|ref|className|style|children)$/]",
        "message": "<KbdHint> doesn't accept that prop. Declared props: keys."
      },
      {
        "selector": "JSXOpeningElement[name.name='LabelChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|color|key|ref|className|style|children)$/]",
        "message": "<LabelChip> doesn't accept that prop. Declared props: name, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriorityIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|size|key|ref|className|style|children)$/]",
        "message": "<PriorityIcon> doesn't accept that prop. Declared props: level, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|key|ref|className|style|children)$/]",
        "message": "<SegmentedOption> doesn't accept that prop. Declared props: value, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|label|key|ref|className|style|children)$/]",
        "message": "<StatusPill> doesn't accept that prop. Declared props: kind, label."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
